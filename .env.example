# Copy this file to .env and fill in the values.

# Pararius search URL with all filters encoded (city, max rent, rooms, etc.)
# Example: https://www.pararius.com/apartments/amsterdam/0-1500/2-bedrooms
PARARIUS_SEARCH_URL=https://www.pararius.com/apartments/your-city/0-your-max-rent/your-min-rooms-bedrooms

# Telegram @username(s) to notify. Comma-separated for multiple recipients.
# Example: @johndoe  or  @johndoe, @janedoe
# Setup: each recipient must start @CallMeBot_txtbot on Telegram and send /start
CALLMEBOT_TELEGRAM_USERNAME=@your_telegram_username

# How often to poll Pararius (seconds). Default: 300 (5 minutes)
POLL_INTERVAL_SECONDS=300

# Delay between successive Telegram messages (seconds). Default: 2
NOTIFICATION_DELAY_SECONDS=2
